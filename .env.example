# SMB settings
SMB_USER=micam
SMB_PASSWORD=change-me
SMB_WORKGROUP=WORKGROUP
SMB_SHARE_NAME=MI_CAMERA
SMB_MIN_PROTOCOL=NT1
SMB_MAX_PROTOCOL=SMB3
SMB_ENABLE_LANMAN=no

# API/UI settings
API_HOST=0.0.0.0
API_PORT=8080
API_TOKEN=
API_ALLOW_NO_TOKEN=true

# Local paths
INBOX_PATH=/data/inbox
STATE_DB_PATH=/data/state/state.db
WEBDAV_MOUNT_PATH=/mnt/webdav

# WebDAV remote (mounted by rclone)
WEBDAV_URL=https://alist.example.com/dav
WEBDAV_USER=admin
WEBDAV_PASS=change-me
WEBDAV_REMOTE_PATH=/camera-backup

# Sync/runtime tuning
SYNC_DELAY_SECONDS=300
SCAN_INTERVAL_SECONDS=10
TARGET_SUBDIR=camera
DELETE_AFTER_SYNC=false
SYNC_RETRY_BASE_SECONDS=15
SYNC_RETRY_MAX_SECONDS=600
SYNC_COPY_CHUNK_BYTES=1048576
SYNC_MAX_WORKERS=1
